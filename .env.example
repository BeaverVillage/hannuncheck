# Cloudflare Pages > Settings > Environment variables 에 등록하세요.
# 공공데이터포털 일반 인증키는 가능하면 Encoding 키를 넣으세요.

# 국세청 사업자등록정보 API와 공정위 통신판매사업자 API를 같은 공공데이터포털 키로 사용할 경우
DATA_GO_KR_SERVICE_KEY=

# API별로 분리하고 싶을 경우 아래 변수 사용
NTS_SERVICE_KEY=
FTC_SERVICE_KEY=

# 선택: 추후 Turnstile을 붙일 때 사용할 수 있습니다. 현재 v2에서는 사용하지 않습니다.
TURNSTILE_SECRET_KEY=

# 선택: 식품안전나라 바코드 보조 조회 API 키
FOODSAFETYKOREA_KEY=
